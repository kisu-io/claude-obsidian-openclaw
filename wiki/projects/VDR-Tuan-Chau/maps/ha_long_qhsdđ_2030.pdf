<!-- ========================================== -->
<!-- SCRIPT JS ĐIỀU KHIỂN WIDGET -->
<!-- ========================================== -->
<script type="pmdelayedscript" data-cfasync="false" data-no-optimize="1" data-no-defer="1" data-no-minify="1">
  document.addEventListener('DOMContentLoaded', function() {
    const toggleButton = document.getElementById('lawfirm-toggle');
    const content = document.getElementById('lawfirm-content');
    const closeButton = document.getElementById('lawfirm-close');

    // Các thành phần của Modal
    const callBtn = document.querySelector('.lawfirm-btn.call');
    const callModal = document.getElementById('lawfirm-call-modal');
    const btnCancel = document.getElementById('modal-btn-cancel');
    const btnConfirm = document.getElementById('modal-btn-confirm');

    // Xử lý ẩn hiện Widget Mobile
    toggleButton.addEventListener('click', function() {
      content.style.display = 'flex';
      toggleButton.style.display = 'none';
    });

    closeButton.addEventListener('click', function() {
      content.style.display = 'none';
      toggleButton.style.display = 'flex';
    });

    function checkScreenSize() {
      if (window.innerWidth < 768) {
        if (content.style.display !== 'flex') {
          toggleButton.style.display = 'flex';
        } else {
          toggleButton.style.display = 'none';
        }
      } else {
        toggleButton.style.display = 'none';
        content.style.display = 'flex';
      }
    }

    checkScreenSize();
    
    let resizeTimer;
    window.addEventListener('resize', function() {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(checkScreenSize, 100);
    });

    // =======================================
    // XỬ LÝ SỰ KIỆN NÚT GỌI ĐIỆN
    // =======================================
    callBtn.addEventListener('click', function(e) {
      // NGĂN CHẶN trình duyệt thực hiện lệnh gọi ngay lập tức
      e.preventDefault(); 
      
      // Hiển thị hộp thoại cảnh báo (Modal)
      callModal.classList.add('show');
    });

    // Nếu nhấn "Hủy" -> Ẩn Modal
    btnCancel.addEventListener('click', function() {
      callModal.classList.remove('show');
    });

    // Nếu nhấn "Vẫn gọi" -> Lấy số điện thoại từ href và thực hiện cuộc gọi
    btnConfirm.addEventListener('click', function() {
      callModal.classList.remove('show');
      const phoneNumberLink = callBtn.getAttribute('href'); // Lấy link tel:0782244468
      window.location.href = phoneNumberLink; // Thực thi lệnh gọi
    });

    // Nhấn ra ngoài modal để đóng
    callModal.addEventListener('click', function(e) {
      if (e.target === callModal) {
        callModal.classList.remove('show');
      }
    });
  });
</script><div id="selectShareContainer">
