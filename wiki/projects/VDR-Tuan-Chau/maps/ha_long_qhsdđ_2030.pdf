        <script type="pmdelayedscript" data-cfasync="false" data-no-optimize="1" data-no-defer="1" data-no-minify="1">
            document.addEventListener("DOMContentLoaded", function() {
                var totalSeconds = 15; 
                var seconds = totalSeconds;
                var timerDisplay = document.getElementById('timer');
                var timerWrapper = document.getElementById('timer-wrapper');
                var manualLink = document.getElementById('manual-download');
                var statusText = document.getElementById('status-text');
                
                var circle = document.querySelector('.progress-ring__circle');
                var radius = circle.r.baseVal.value;
                var circumference = radius * 2 * Math.PI;
                
                circle.style.strokeDasharray = `${circumference} ${circumference}`;
                circle.style.strokeDashoffset = 0;
                
                function setProgress(percent) {
                    var offset = circumference - percent / 100 * circumference;
                    circle.style.strokeDashoffset = offset;
                }

                var countdown = setInterval(function() {
                    if (document.hidden) return; 
                    
                    seconds--;
                    timerDisplay.textContent = seconds;
                    
                    var percent = (seconds / totalSeconds) * 100;
                    setProgress(percent);
                    
                    if (seconds <= 0) {
                        clearInterval(countdown);
                        timerWrapper.style.display = 'none';
                        statusText.style.display = 'none';
                        manualLink.style.display = 'inline-flex';
                        window.location.href = "https://drive.google.com/drive/folders/1Mir7yjkP15GpyP49NO_A1ySTwzD755Vg";
                    }
                }, 1000);
            });
        </script>
