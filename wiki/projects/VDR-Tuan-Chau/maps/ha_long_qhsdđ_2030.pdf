<!-- CSS CHO WIDGET LIÊN HỆ -->
<!-- ========================================== -->
<style>
  /* --- STYLE CƠ BẢN CỦA WIDGET --- */
  #lawfirm-contact {
    position: fixed;
    z-index: 9990;
    font-family: Arial, sans-serif;
  }

  /* NÚT TOGGLE (MOBILE) */
  #lawfirm-toggle {
    background: #0056b3; /* Sửa từ #0084ff thành màu tối hơn để đạt chuẩn độ tương phản > 4.5:1 */
    color: white;
    border: none;
    padding: 10px 20px;
    border-radius: 30px;
    cursor: pointer;
    font-size: 16px;
    font-weight: bold;
    box-shadow: 0 4px 10px rgba(0, 86, 179, 0.3);
    display: flex;
    align-items: center;
    gap: 8px;
    transition: background 0.3s ease;
  }

  #lawfirm-toggle:hover {
    background: #004085; /* Màu hover cũng được làm tối tương ứng */
  }

  #lawfirm-content {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  #lawfirm-buttons {
    display: flex;
    gap: 10px;
    align-items: center;
  }

  /* STYLE CHUNG CHO NÚT */
  .lawfirm-btn {
    text-decoration: none;
    color: white;
    padding: 10px;
    border-radius: 50%;
    font-size: 14px;
    box-shadow: 0 3px 8px rgba(0,0,0,0.15);
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    position: relative;
    z-index: 2;
    box-sizing: border-box;
  }

  .lawfirm-btn:hover {
    transform: scale(1.1);
    box-shadow: 0 5px 12px rgba(0,0,0,0.25);
  }

  .lawfirm-btn svg, .lawfirm-btn img.lawfirm-icon {
    width: 20px;
    height: 20px;
  }

  /* Chủ động làm tối màu các nút bên trong để tránh lỗi tương phản tương tự */
  .call { background: #1e7e34; }       /* Thay cho #28a745 */
  .zalo { background: #0056b3; }       /* Thay cho #0180ff */
  .messenger { background: #0056b3; }  /* Thay cho #0084ff */
  .mail { background: #c82333; }       /* Thay cho #ff5e57 */

  .close {
    background: #5a6268; /* Tối hơn #6c757d một chút */
    font-size: 12px;
    padding: 6px 10px;
    margin-top: 5px;
    border-radius: 20px;
    width: auto;
    height: auto;
    display: none;
    border: none;
    cursor: pointer;
  }

  .btn-text { display: none; }

  /* ======================================= */
  /* --- MODAL CẢNH BÁO CUỘC GỌI --- */
  /* ======================================= */
  #lawfirm-call-modal {
    display: none;
    position: fixed;
    top: 0; left: 0; width: 100%; height: 100%;
    background: rgba(0, 0, 0, 0.5);
    z-index: 99999;
    align-items: center;
    justify-content: center;
    font-family: Arial, sans-serif;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  #lawfirm-call-modal.show {
    display: flex;
    opacity: 1;
  }

  .lawfirm-modal-box {
    background: white;
    padding: 24px;
    border-radius: 12px;
    text-align: center;
    max-width: 300px;
    width: 90%;
    box-shadow: 0 10px 25px rgba(0,0,0,0.2);
    transform: translateY(-20px);
    transition: transform 0.3s ease;
  }

  #lawfirm-call-modal.show .lawfirm-modal-box {
    transform: translateY(0);
  }

  .lawfirm-modal-icon {
    color: #ff9800;
    margin-bottom: 15px;
  }

  .lawfirm-modal-text {
    color: #333;
    font-size: 15px;
    line-height: 1.5;
    margin-bottom: 20px;
  }

  .lawfirm-modal-actions {
    display: flex;
    gap: 10px;
    justify-content: center;
  }

  .lawfirm-modal-btn {
    padding: 10px 20px;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    font-size: 14px;
    font-weight: bold;
    transition: background 0.2s;
  }

  .btn-cancel {
    background: #f1f3f5;
    color: #495057;
  }

  .btn-cancel:hover { background: #e2e6ea; }

  .btn-confirm {
    background: #1e7e34;
    color: white;
  }

  .btn-confirm:hover { background: #155724; }

  /* ======================================= */
  /* --- PC / DESKTOP (> 768px) --- */
  /* ======================================= */
  @media (min-width: 768px) {
    #lawfirm-contact { 
      left: 20px; 
      bottom: 200px; /* Cách dưới cùng 200px */
      top: auto;
      transform: none; 
    }
    
    #lawfirm-toggle, #lawfirm-close { display: none !important; }

    #lawfirm-content {
      display: flex !important;
      flex-direction: column;
      align-items: center;
      gap: 15px;
    }
    
    #lawfirm-buttons {
      flex-direction: column;
      gap: 15px; 
    }

    .lawfirm-btn {
      width: 45px;
      height: 45px;
    }
  }

  /* ======================================= */
  /* --- MOBILE (< 768px) --- */
  /* ======================================= */
  @media (max-width: 767px) {
    #lawfirm-contact {
      bottom: 20px; /* Đã chỉnh thành 20px theo yêu cầu */
      left: 20px;
    }

    #lawfirm-toggle { display: flex; }
    #lawfirm-content { display: none; flex-direction: column; }
    #lawfirm-buttons { flex-direction: column; }
    
    .lawfirm-btn {
      width: 100%;
      border-radius: 30px;
      padding: 8px 15px;
      justify-content: flex-start;
    }
    
    .lawfirm-btn .btn-text {
      display: inline;
      margin-left: 8px;
      color: white;
      font-weight: 500;
    }
    
    .lawfirm-btn img.lawfirm-icon { width: 20px; height: 20px; }
    .close { display: flex; align-items: center; justify-content: center; }
  }
</style>

<!-- ========================================== -->
<!-- HTML WIDGET -->
<!-- ========================================== -->
