                <style>
            .wth-dl-page-container {
                --primary: #2563eb; --primary-hover: #1d4ed8; --bg-color: #f1f5f9; --card-bg: #ffffff;
                --text-main: #1e293b; --text-muted: #64748b; --border-color: #e2e8f0;
                background-color: var(--bg-color); padding: 60px 15px; font-family: 'Inter', sans-serif;
                color: var(--text-main); min-height: 60vh;
            }
            .wth-dl-page-container * { box-sizing: border-box; }
            .wth-dl-page-container .download-wrapper { width: 100%; max-width: 1000px; margin: 0 auto; }
            .wth-dl-page-container .download-card { background: var(--card-bg); border-radius: 16px; box-shadow: 0 10px 30px rgba(0,0,0,0.08); overflow: hidden; display: flex; flex-direction: column; }
            .wth-dl-page-container .dc-layout { display: flex; flex-direction: row; }
            .wth-dl-page-container .dc-main { flex: 5.5; padding: 50px 40px; display: flex; flex-direction: column; justify-content: center; align-items: center; text-align: center; }
            .wth-dl-page-container .dc-sidebar { flex: 4.5; background: #f8fafc; border-left: 1px solid var(--border-color); padding: 40px 30px; display: flex; flex-direction: column; justify-content: center; }
            
            .wth-dl-page-container .dc-main h1 { font-size: 24px; font-weight: 700; color: var(--text-main); margin: 0 0 10px 0; line-height: 1.3; }
            .wth-dl-page-container .dc-main p { color: var(--text-muted); font-size: 15px; margin: 0 0 20px 0; }
            .wth-dl-page-container .file-name { display: inline-block; background: #eff6ff; color: var(--primary); padding: 8px 16px; border-radius: 20px; font-size: 14px; font-weight: 500; margin-bottom: 25px; word-break: break-word;}
            
            .wth-dl-page-container .timer-container { position: relative; width: 140px; height: 140px; margin: 20px auto 30px; }
            .wth-dl-page-container .progress-ring { transform: rotate(-90deg); }
            .wth-dl-page-container .progress-ring__circle { transition: stroke-dashoffset 1s linear; }
            .wth-dl-page-container .timer-text { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); font-size: 42px; font-weight: 800; color: var(--primary); line-height: 1; margin: 0; }
            
            .wth-dl-page-container .manual-link { display: none; background-color: var(--primary); color: #ffffff; padding: 14px 32px; border-radius: 8px; text-decoration: none; font-weight: 600; font-size: 16px; box-shadow: 0 4px 12px rgba(37, 99, 235, 0.25); transition: all 0.3s ease; align-items: center; justify-content: center; gap: 8px; cursor: pointer; }
            .wth-dl-page-container .manual-link:hover { background-color: var(--primary-hover); transform: translateY(-2px); box-shadow: 0 6px 16px rgba(37, 99, 235, 0.3); color: #ffffff; }
            .wth-dl-page-container .manual-link svg { width: 20px; height: 20px; fill: currentColor; }

            .wth-dl-page-container .adsense-placeholder { background: #fff; border: 1px solid var(--border-color); border-radius: 8px; min-height: 250px; display: flex; align-items: center; justify-content: center; margin-bottom: 25px; overflow: hidden; }
            .wth-dl-page-container .wth-ad-container { overflow: hidden; display: flex; justify-content: center; align-items: center; background: #fff; width: 100%; }
            
            .wth-dl-page-container .donate-box { background: #fff; border: 1px solid var(--border-color); border-radius: 12px; padding: 20px; text-align: center; box-shadow: 0 2px 8px rgba(0,0,0,0.02); }
            .wth-dl-page-container .donate-title { font-weight: 600; color: var(--text-main); font-size: 14px; margin: 0 0 12px 0; display: flex; align-items: center; justify-content: center; gap: 8px; }
            .wth-dl-page-container .donate-box img { max-width: 100%; border-radius: 6px; }

            @media (max-width: 768px) {
                .wth-dl-page-container .dc-layout { flex-direction: column; }
                .wth-dl-page-container .dc-sidebar { border-left: none; border-top: 1px solid var(--border-color); padding: 30px 20px; }
                .wth-dl-page-container .dc-main { padding: 40px 20px; }
                .wth-dl-page-container .timer-container { width: 120px; height: 120px; }
                .wth-dl-page-container .timer-text { font-size: 36px; }
            }
