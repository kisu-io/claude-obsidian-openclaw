<!-- HTML MODAL CẢNH BÁO -->
<!-- ========================================== -->
<div id="lawfirm-call-modal">
  <div class="lawfirm-modal-box">
    <div class="lawfirm-modal-icon">
      <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="currentColor" viewBox="0 0 24 24">
