<script type="text/javascript" src="https://lawfirm.vn/wp-content/plugins/luckywp-table-of-contents/front/assets/main.min.js?ver=2.1.14" id="lwptoc-main-js" defer></script>
<script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-5368448643359626" crossorigin="anonymous" type="pmdelayedscript" data-cfasync="false" data-no-optimize="1" data-no-defer="1" data-no-minify="1"></script>        <style>
            .sce-faq-item {
                background-color: #f7f8f9; /* Nền xám nhạt */
                margin-bottom: 15px;       /* Khoảng cách giữa các box */
                border-radius: 6px;        /* Bo góc nhẹ nhàng */
                overflow: hidden;
            }
            .sce-faq-question {
                cursor: pointer;
                padding: 20px 25px;        /* Khoảng cách viền vào chữ rộng rãi */
                outline: none;
                list-style: none;          /* Ẩn mũi tên mặc định của trình duyệt */
                position: relative;
            }
            /* Reset margin/padding cho thẻ h3 bên trong summary */
            .sce-faq-title {
                margin: 0 !important;
                padding: 0 !important;
                font-size: 1.1em;
                font-weight: 700;          /* In đậm giống trong ảnh */
                color: #111;               /* Màu đen sắc nét */
                display: inline-block;
                width: 90%;                /* Chừa chỗ cho mũi tên bên phải */
                line-height: 1.4;
            }
            /* Ẩn mũi tên mặc định trên Chrome/Safari */
            .sce-faq-question::-webkit-details-marker {
                display: none; 
            }
            /* Tạo icon mũi tên (Chevron) gập xuống bằng CSS */
            .sce-faq-question::after {
                content: "";
                position: absolute;
                right: 25px;               /* Căn lề phải bằng với padding */
                top: 50%;
                width: 10px;
                height: 10px;
                border-right: 3px solid #222; /* Độ dày của mũi tên */
                border-bottom: 3px solid #222;
                transform: translateY(-70%) rotate(45deg);
                transition: transform 0.3s ease; /* Hiệu ứng xoay mượt mà */
            }
            /* Xoay mũi tên lên trên khi mở FAQ */
            .sce-faq-item[open] .sce-faq-question::after {
                transform: translateY(-30%) rotate(225deg);
            }
            .sce-faq-answer {
                padding: 0 25px 25px 25px; /* Giữ padding ở dưới và 2 bên, bỏ ở trên */
                color: #333;               /* Chữ nội dung xám đen */
                line-height: 1.7;          /* Tăng khoảng cách dòng cho dễ đọc */
            }
            /* Format lại các tag cơ bản bên trong phần trả lời */
            .sce-faq-answer p { margin-bottom: 15px; }
            .sce-faq-answer p:last-child { margin-bottom: 0; }
            .sce-faq-answer ul { margin-left: 20px; margin-bottom: 15px; list-style-type: disc; }
            .sce-faq-answer ol { margin-left: 20px; margin-bottom: 15px; }
        </style>
